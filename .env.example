# OpenAI
OPENAI_API_KEY=your_openai_key_here

# CORS — set to your Railway app URL in production
# Local dev: leave as * or omit entirely
ALLOWED_ORIGINS=https://your-app.up.railway.app

# SQLite database file path
# On Railway: mount a volume and point DB_PATH to it (e.g. /data/tweet_engine.db)
DB_PATH=tweet_engine.db

# Port (Railway sets this automatically; only needed for local overrides)
PORT=8000
